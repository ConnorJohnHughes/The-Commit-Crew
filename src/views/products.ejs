<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png"  href="/images/Powerdrip.png">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/styles.css" />

  <!-- Pure CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/purecss@3.0.0/build/pure-min.css" integrity="sha384-X38yfunGUhNzHpBaEBsWLO+A0HDYOQi8ufWDkZ0k9e0eXz/tH3II7uKZ9msv++Ls" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/purecss@3.0.0/build/grids-responsive-min.css">
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Protest+Strike&display=swap" rel="stylesheet">

  <script src="/js/products-filter.js" defer></script>
</head>
<body>
  
  <%- include ("partials/header") %>

<main>
  
  <div class="products-toolbar">
    <h1><%= title %></h1>
    <input
      id="searchInput"
      type="text"
      placeholder="Search products..."
    >

    <select id="categorySelect">
      <option value="">All Categories</option>
      <option value="smoothie">Smoothie</option>
      <option value="drink">Drink</option>
      <option value="powder">Powder</option>
    </select>

    <select id="sortSelect">
      <option value="">Featured</option>
      <option value="price">Price</option>
    </select>
  </div>

  <div id="productsGrid" class="products-grid pure-g">
    
  </div>
  
  <script src="/js/cart.js"></script>
  <script src="/js/products.js"></script>
</main>

  <%- include("partials/footer") %>


</body>
</html>