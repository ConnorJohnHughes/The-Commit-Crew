<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/png"  href="/images/Powerdrip.png">

  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Protest+Strike&display=swap" rel="stylesheet">

  <script src="/js/products-filter.js" defer></script>
</head>
<body>
  
  <%- include ("partials/header") %>

<main>
  <h1><%= title %></h1>

  <div id="productsGrid" class="products-grid">
    <% if (products && products.length > 0 ) { %>

      <% products.forEach(product => { %>

        <a href="/products/<%= product.id %>" class="product-card">

          <div class="product-image">
            <img src="<%= product.image %>" alt="<%= product.name %>">
          </div>

          <div class="product-info">
            <h3><%= product.name %></h3>
            <p class="price">$<%= product.price %></p>
          </div>

        </a>

      <% }) %>

    <% } else { %>
      <p>No products found.</p>
    <% } %>
  </div>

</main>

  <%- include("partials/footer") %>


</body>
</html>